{
  "name": "project-lanes",
  "displayName": "Project Lanes - Fast Switching",
  "version": "0.1.5",
  "description": "Manage projects as lanes within a workspace and switch Explorer, terminals, and editor tabs in one click",
  "categories": [
    "Other"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/YukiIto1999/vscode-project-lanes"
  },
  "publisher": "yukiito1999",
  "main": "./dist/extension.js",
  "scripts": {
    "build": "vp build",
    "watch": "vp build --watch",
    "test": "vp test run",
    "test:watch": "vp test",
    "lint": "vp lint",
    "fmt": "vp fmt",
    "check": "vp check",
    "package": "vsce package"
  },
  "dependencies": {
    "node-pty": "^1.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.101.0",
    "typescript": "^5.7.0",
    "vite-plus": "^0.1.16"
  },
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "project-lanes",
          "title": "Project Lanes",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "project-lanes": [
        {
          "id": "projectLanes",
          "name": "Lanes"
        }
      ]
    },
    "commands": [
      {
        "command": "projectLanes.focus",
        "title": "Focus",
        "category": "Project Lanes"
      },
      {
        "command": "projectLanes.closeTerminals",
        "title": "Close Terminals",
        "category": "Project Lanes"
      },
      {
        "command": "projectLanes.addFolder",
        "title": "Add Folder to Workspace",
        "category": "Project Lanes",
        "icon": "$(add)"
      },
      {
        "command": "projectLanes.reloadLanes",
        "title": "Reload Lanes",
        "category": "Project Lanes",
        "icon": "$(refresh)"
      },
      {
        "command": "projectLanes.renameLane",
        "title": "Rename Lane",
        "category": "Project Lanes"
      },
      {
        "command": "projectLanes.removeLane",
        "title": "Remove Lane",
        "category": "Project Lanes"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "projectLanes.addFolder",
          "when": "view == projectLanes",
          "group": "navigation@1"
        },
        {
          "command": "projectLanes.reloadLanes",
          "when": "view == projectLanes",
          "group": "navigation@2"
        }
      ],
      "view/item/context": [
        {
          "command": "projectLanes.renameLane",
          "when": "view == projectLanes && viewItem == projectLane",
          "group": "1_modify@1"
        },
        {
          "command": "projectLanes.removeLane",
          "when": "view == projectLanes && viewItem == projectLane",
          "group": "1_modify@2"
        }
      ]
    },
    "configuration": {
      "title": "Project Lanes",
      "properties": {
        "projectLanes.terminal.shellPath": {
          "type": "string",
          "default": "",
          "description": "Shell path for Lane Terminal. Leave empty to auto-detect from $SHELL."
        },
        "projectLanes.activity.showIndicator": {
          "type": "boolean",
          "default": true,
          "description": "Show running indicator in badge, decoration, and status bar when a lane has an executing terminal."
        }
      }
    },
    "terminal": {
      "profiles": [
        {
          "id": "projectLanes.terminal",
          "title": "Lane Terminal"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "projectLanes",
        "contents": "This extension requires a workspace file (.code-workspace).\n[Open Workspace File](command:workbench.action.openWorkspace)",
        "when": "workbenchState != workspace"
      },
      {
        "view": "projectLanes",
        "contents": "No lanes yet.\n[Add Folder to Workspace](command:projectLanes.addFolder)",
        "when": "workbenchState == workspace"
      }
    ]
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "icon": "media/icon.png",
  "engines": {
    "vscode": "^1.101.0"
  }
}
